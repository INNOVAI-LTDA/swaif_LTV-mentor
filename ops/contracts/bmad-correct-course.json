    "correction-memo"
  ],
  "required_response_fields": [
    "status",
    "summary",
    "decisions",
    "risks",
    "input_artifacts",
    "output_artifacts",
    "approval_required"
  ],
  "default_next_command": "bmad-create-story",
  "artifact_path_guidance": [
    {
      "artifact_type": "correction-memo",
      "path_hint": "_bmad-output/operator-artifacts/<scope>-correction-memo.md"
    }
  ]
}
