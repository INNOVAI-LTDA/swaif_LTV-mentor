# Explicit deploy target. Use `local` for development and `client` for published builds.
VITE_DEPLOY_TARGET=local
# Local-only example. Client target requires an explicit absolute URL without credentials, query strings, or fragments.
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_HTTP_TIMEOUT_MS=15000
# Optional subpath deployment. Use "/" for root deployment.
VITE_APP_BASE_PATH=/
# Brand and product identity. Replace these values before client delivery.
VITE_CLIENT_NAME=Cliente
VITE_APP_NAME=Plataforma de Mentoria
VITE_APP_TAGLINE=Acompanhamento com visao operacional
VITE_SHELL_SUBTITLE=Operacao, acompanhamento e governanca
VITE_BRANDING_ICON_PATH=branding/app-icon.png
VITE_BRANDING_LOGO_PATH=branding/app-logo.png
VITE_BRANDING_LOGIN_HERO_PATH=branding/login-hero.png
# Internal/demo only. Keep disabled for client environments.
VITE_ENABLE_DEMO_MODE=false
# Local-only mentor workspace backed by the current mentor-demo routes. Keep disabled for client environments.
VITE_ENABLE_INTERNAL_MENTOR_DEMO=false

# Published client example:
# VITE_DEPLOY_TARGET=client
# VITE_API_BASE_URL=https://api.example.com
# VITE_APP_BASE_PATH=/cliente/
# VITE_CLIENT_NAME=Nome do Cliente
# VITE_APP_NAME=Nome do Produto
# VITE_APP_TAGLINE=Mensagem curta do produto
# VITE_ENABLE_DEMO_MODE=false
# VITE_ENABLE_INTERNAL_MENTOR_DEMO=false
