# Vercel Production example (non-secret placeholders)
VITE_DEPLOY_TARGET=client
VITE_APP_BASE_PATH=/
VITE_API_BASE_URL=https://api-accmed.innovai-solutions.com.br
VITE_CLIENT_CODE=accmed

# Optional branding (safe placeholders)
VITE_CLIENT_NAME=Cliente Producao
VITE_APP_NAME=Mentoria
VITE_APP_TAGLINE=Entrega ao cliente
VITE_SHELL_SUBTITLE=Ambiente de producao
VITE_BRANDING_ICON_PATH=branding/app-icon.png
VITE_BRANDING_LOGO_PATH=branding/app-logo.png
VITE_BRANDING_LOGIN_HERO_PATH=branding/login-hero.png

# Flags should remain false for hosted client builds
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_INTERNAL_MENTOR_DEMO=false
