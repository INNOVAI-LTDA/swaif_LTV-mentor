# Preview environment (Vercel Preview)
VITE_DEPLOY_TARGET=client
VITE_CLIENT_CODE=preview-client
VITE_API_BASE_URL=https://api-preview.example.com
VITE_HTTP_TIMEOUT_MS=15000
# Root deployment by default; adjust if the preview app must live under a subpath.
VITE_APP_BASE_PATH=/
# Branding and product identity for preview builds.
VITE_CLIENT_NAME=Cliente Preview
VITE_APP_NAME=Plataforma de Mentoria (Preview)
VITE_APP_TAGLINE=Validação pré-produção
VITE_SHELL_SUBTITLE=Operacao, acompanhamento e governanca
VITE_BRANDING_ICON_PATH=branding/app-icon.png
VITE_BRANDING_LOGO_PATH=branding/app-logo.png
VITE_BRANDING_LOGIN_HERO_PATH=branding/login-hero.png
# Feature flags must stay explicit.
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_INTERNAL_MENTOR_DEMO=false
