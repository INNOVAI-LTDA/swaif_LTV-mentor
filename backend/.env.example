# Application environment. Required in all environments.
# Use `local` for development and a production-like value for deployed environments.
APP_ENV=local
# Explicit backend client identifier. Required for all startup modes.
# Must match frontend VITE_CLIENT_CODE in the same deployment.
CLIENT_CODE=local

# Comma-separated list of allowed frontend origins.
# Local-only example. Required when APP_ENV is production-like.
# Use bare origins only, without credentials, paths, query strings, or fragments.
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5175,http://localhost:5175,http://127.0.0.1:5176,http://localhost:5176

# Local-only toggle for mentor demo routes.
# Defaults to true in local/test and false in production-like environments.
ENABLE_MENTOR_DEMO_ROUTES=true

# Remote-only approval gate for mentor demo routes.
# Required together with ENABLE_MENTOR_DEMO_ROUTES=true when APP_ENV is production-like.
ALLOW_REMOTE_MENTOR_DEMO_ROUTES=false

# Directory used by `py -m app.operations.storage_maintenance backup`.
# Keep this on the same server and include it in operator runbooks.
STORAGE_BACKUP_DIR=backups

# Auth signing secret. Required for any deployed environment.
# Do not reuse the development fallback from app.api.routes.auth in remote environments.
APP_AUTH_SECRET=change-me

# Railway / published backend example (production-only CORS posture):
# APP_ENV=production
# CLIENT_CODE=accmed
# CORS_ALLOW_ORIGINS=https://accmed.innovai-solutions.com.br
# ENABLE_MENTOR_DEMO_ROUTES=false
# ALLOW_REMOTE_MENTOR_DEMO_ROUTES=false
# APP_AUTH_SECRET=<strong-random-secret>
# STORAGE_BACKUP_DIR=/app/data/backups
#
# Optional Preview-enabled posture:
# APP_ENV=production
# CLIENT_CODE=accmed
# CORS_ALLOW_ORIGINS=https://accmed.innovai-solutions.com.br
# CORS_ALLOW_ORIGIN_REGEX=^https://.*\.vercel\.app$
# ENABLE_MENTOR_DEMO_ROUTES=false
# ALLOW_REMOTE_MENTOR_DEMO_ROUTES=false
# APP_AUTH_SECRET=<strong-random-secret>
# STORAGE_BACKUP_DIR=/app/data/backups
#
# Railway storage contract:
# - set the Railway service root to `backend`
# - mount the Railway volume at `/app/data`
# - keep the individual `*_STORE_PATH` env vars unset unless you intentionally override the default JSON store layout
# - with the root/mount pairing above, the default store files remain durable under `/app/data/*.json`

# Misconfigured example (must fail at startup):
# APP_ENV=production
# CLIENT_CODE=
# CORS_ALLOW_ORIGINS=https://accmed.innovai-solutions.com.br

# For client-specific local startup, prefer a profile such as `.env.client.accmed.example`
# together with `scripts\mvp_bootstrap.bat --client-code accmed`.
