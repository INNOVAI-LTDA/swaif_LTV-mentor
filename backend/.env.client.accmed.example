# Client-specific local template for Grupo Acelerador Medico (AccMed).
# This file can be loaded directly by the local bootstrap using `--client-code accmed`.
APP_ENV=local
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173
ENABLE_MENTOR_DEMO_ROUTES=false
ALLOW_REMOTE_MENTOR_DEMO_ROUTES=false
STORAGE_BACKUP_DIR=backups
CLIENT_CODE=accmed
CLIENT_NAME=Grupo Acelerador Medico
CLIENT_PRODUCT_NAME=Gamma
