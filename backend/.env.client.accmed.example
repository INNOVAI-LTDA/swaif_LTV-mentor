# Client-specific local template for Grupo Acelerador Médico (AccMed).
# This file can be loaded directly by the local bootstrap using `--client-code accmed`.
APP_ENV=local
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5175,http://localhost:5175
ENABLE_MENTOR_ROUTES=true
STORAGE_BACKUP_DIR=backups
CLIENT_CODE=accmed
CLIENT_NAME=Grupo Acelerador Médico
CLIENT_PRODUCT_NAME=Gamma
